{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "supernote",
  "version": "0.1.0",
  "identifier": "com.nikhi.supernote",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "supernote",
        "width": 800,
        "height": 600,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
   "os": {}
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "externalBin": [
      "../src-sidecars/src-bun/bun-sidecar",
      "../src-sidecars/src-python/python-sidecar"
    ]
  }
}
